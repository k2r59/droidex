# --- Base de données ---
NUXT_MONGODB_URI=mongodb://localhost:27017
NUXT_MONGODB_DB_NAME=droidex

# --- BetterAuth ---
# Génère un secret : openssl rand -base64 32
NUXT_BETTER_AUTH_SECRET=
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Connexion sociale ---
# Redirection à déclarer chez chaque fournisseur :
#   {NUXT_PUBLIC_BASE_URL}/api/auth/callback/{discord|google|twitch}
NUXT_DISCORD_CLIENT_ID=
NUXT_DISCORD_CLIENT_SECRET=
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_TWITCH_CLIENT_ID=
NUXT_TWITCH_CLIENT_SECRET=

# --- Images des droids ---
# Par défaut servies depuis /droids (voir `pnpm run fetch:images`).
# Pointe vers un CDN en production si tu préfères.
NUXT_PUBLIC_DROID_IMAGE_BASE=/droids
